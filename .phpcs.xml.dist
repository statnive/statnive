<?xml version="1.0"?>
<ruleset name="Statnive">
	<description>WordPress Coding Standards for Statnive plugin.</description>

	<!-- Scan source files -->
	<file>./src</file>
	<file>./statnive.php</file>
	<file>./uninstall.php</file>

	<!-- Exclude generated/vendor code -->
	<exclude-pattern>./src/Dependencies/*</exclude-pattern>
	<exclude-pattern>./vendor/*</exclude-pattern>
	<exclude-pattern>./node_modules/*</exclude-pattern>
	<exclude-pattern>./tests/*</exclude-pattern>

	<!-- Use WordPress standards -->
	<rule ref="WordPress">
		<!-- Allow short array syntax -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		<!-- PSR-4 uses PascalCase filenames, not WP hyphenated-lowercase -->
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<!-- File doc comments are redundant with class doc comments -->
		<exclude name="Squiz.Commenting.FileComment.Missing"/>
		<!-- WP_REST_Controller properties are inherited — no docblocks needed -->
		<exclude name="Squiz.Commenting.VariableComment.Missing"/>
	</rule>

	<!-- WordPress Extra standards -->
	<rule ref="WordPress-Extra"/>

	<!-- Plugin text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="statnive"/>
			</property>
		</properties>
	</rule>

	<!-- Minimum WordPress and PHP versions -->
	<config name="minimum_wp_version" value="6.2"/>
	<config name="minimum_supported_wp_version" value="5.6"/>

	<!-- PHP compatibility (matches Requires PHP: 8.0 in statnive.php) -->
	<rule ref="PHPCompatibilityWP"/>
	<config name="testVersion" value="8.0-"/>

	<!-- PHP compatibility -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="statnive"/>
				<element value="Statnive"/>
				<element value="STATNIVE"/>
			</property>
		</properties>
	</rule>

	<!-- Show colors and progress -->
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- Warnings are informative, not build-breaking.
	     Errors still fail the build. -->
	<config name="ignore_warnings_on_exit" value="1"/>
</ruleset>
