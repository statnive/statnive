# Docker test environment configuration
# Copy to .env and modify as needed: cp .env.example .env

# WordPress site port (host side)
WP_PORT=8080

# WordPress admin credentials (used by seed script + k6 tests)
WP_ADMIN_USER=admin
WP_ADMIN_PASS=admin
WP_ADMIN_EMAIL=admin@example.com

# Database credentials
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# Statnive tracker HMAC secret (64 chars)
HMAC_SECRET=docker_test_hmac_secret_replace_me_with_64_chars_of_randomness!

# PHP-FPM worker count (4 = good for light tier, 8-16 for medium/heavy)
WP_FPM_WORKERS=4

# WordPress/PHP versions
WP_VERSION=6.9
PHP_VERSION=8.2
