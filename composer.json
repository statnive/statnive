{
	"name": "statnive/statnive",
	"description": "Simple stats, clear decisions. Privacy-first analytics for WordPress.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"homepage": "https://statnive.com",
	"require": {
		"php": ">=8.1",
		"geoip2/geoip2": "^2.13",
		"matomo/device-detector": "^6.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.5",
		"phpstan/phpstan": "^1.12",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"wp-coding-standards/wpcs": "^3.1",
		"phpcompatibility/php-compatibility": "^9.3",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"yoast/phpunit-polyfills": "^3.0",
		"coenjacobs/mozart": "^0.7"
	},
	"autoload": {
		"psr-4": {
			"Statnive\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Statnive\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:unit": "phpunit --testsuite unit",
		"test:integration": "phpunit -c phpunit-integration.xml",
		"phpcs": "phpcs",
		"phpcbf": "phpcbf",
		"phpstan": "phpstan analyse --memory-limit=1G",
		"gate": "@test:unit",
		"release-gate": [
			"@phpcs",
			"@phpstan",
			"@test"
		]
	},
	"extra": {
		"mozart": {
			"dep_namespace": "Statnive\\Dependencies\\",
			"dep_directory": "/src/Dependencies/",
			"classmap_directory": "/src/Dependencies/",
			"classmap_prefix": "Statnive_",
			"packages": ["geoip2/geoip2", "matomo/device-detector"],
			"delete_vendor_directories": true
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	},
	"minimum-stability": "stable",
	"prefer-stable": true
}
